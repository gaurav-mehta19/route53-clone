# ──────────────────────────────────────────────────────────────────────────
# Route 53 Clone — backend env example. Copy to `.env` and edit.
#
#     cp backend/.env.example backend/.env
#
# Every variable is optional; the app boots fine with no .env at all. The
# table below tells you when to override a default.
# ──────────────────────────────────────────────────────────────────────────

# ── Required when deploying behind a different frontend origin ───────────
# JSON array of allowed origins (pydantic-settings parses it into list[str]).
# Include http://localhost:3000 so you can hit prod backend from local dev.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Database ─────────────────────────────────────────────────────────────
# SQLite file relative to the backend working dir. On Render's free tier
# the disk is ephemeral, so the DB resets on every redeploy.
# DATABASE_URL=sqlite:///./route53_clone.db

# ── Auth ─────────────────────────────────────────────────────────────────
# Bearer-token session lifetime, in seconds. Default = 24h.
# SESSION_TTL_SECONDS=86400

# ── Demo credentials shown on the login page ─────────────────────────────
# These are read by `python -m app.seed` to create the demo user. Changing
# them after seeding has no effect unless you re-seed (or the DB resets).
# DEMO_EMAIL=demo@example.com
# DEMO_PASSWORD=demo1234
# DEMO_DISPLAY_NAME=Demo User
